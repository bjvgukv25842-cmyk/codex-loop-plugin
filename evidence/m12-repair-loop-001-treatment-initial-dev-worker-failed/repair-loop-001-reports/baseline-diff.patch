@@ -1,3 +1,13 @@
 export function validateProjectName(name) {
+  if (typeof name !== "string") {
+    return { ok: false };
+  }
+
+  const normalizedName = name.trim();
+
+  if (normalizedName.length === 0 || normalizedName.length > 80) {
+    return { ok: false };
+  }
+
   return { ok: true };
 }
