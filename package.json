{
  "name": "codex-loop-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "Loop-driven Codex plugin scaffold for modular multi-agent delivery.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc --noEmit",
    "validate:manifest": "node src/plugin/validate-manifest.ts",
    "validate": "tsc --noEmit && vitest run && node src/plugin/validate-manifest.ts"
  },
  "keywords": [
    "codex",
    "plugin",
    "multi-agent",
    "loop"
  ],
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
