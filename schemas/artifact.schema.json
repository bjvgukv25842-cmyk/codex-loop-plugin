{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-loop-plugin.dev/schemas/artifact.schema.json",
  "title": "Artifact",
  "type": "object",
  "properties": {
    "artifact_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "loop_run_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "task_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/NullableID"
    },
    "module_id": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "type": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ArtifactType"
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "hash": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "summary": {
      "type": "string"
    },
    "created_by_agent_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "created_at": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ISODateTime"
    },
    "metadata": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/Metadata"
    }
  },
  "required": [
    "artifact_id",
    "loop_run_id",
    "task_id",
    "module_id",
    "type",
    "path",
    "hash",
    "summary",
    "created_by_agent_id",
    "created_at",
    "metadata"
  ],
  "additionalProperties": false
}
