{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-loop-plugin.dev/schemas/repair-request.schema.json",
  "title": "RepairRequest",
  "type": "object",
  "properties": {
    "repair_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "loop_run_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "task_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "module_id": {
      "type": "string",
      "minLength": 1
    },
    "source_eval_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "assigned_agent_id": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ID"
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "https://codex-loop-plugin.dev/schemas/eval-report.schema.json#/$defs/Finding"
      },
      "minItems": 1
    },
    "repair_instructions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "allowed_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disallowed_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_commands": {
      "type": "array",
      "items": {
        "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ValidationCommand"
      }
    },
    "status": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/TaskStatus"
    },
    "created_at": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ISODateTime"
    },
    "updated_at": {
      "$ref": "https://codex-loop-plugin.dev/schemas/common.schema.json#/$defs/ISODateTime"
    }
  },
  "required": [
    "repair_id",
    "loop_run_id",
    "task_id",
    "module_id",
    "source_eval_id",
    "assigned_agent_id",
    "findings",
    "repair_instructions",
    "allowed_scope",
    "disallowed_scope",
    "validation_commands",
    "status",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false
}
